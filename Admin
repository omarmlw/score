<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>لوحة تحكم الأدمن — LiveScores</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&family=Oswald:wght@400;500;700&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      --bg:#05080f;--card:#0b1220;--card2:#0f1a2e;--border:#1a2840;
      --accent:#00d4ff;--accent2:#0090b3;--red:#ff3b3b;--green:#00e676;
      --orange:#ff9800;--gray:#5a6a80;--txt:#e8f1ff;--sub:#7a90b0;
      --gold:#f0c040;--purple:#9c6bff;
      --fa:'Tajawal',sans-serif;--fe:'Oswald',sans-serif;
    }

    body{font-family:var(--fa);background:var(--bg);color:var(--txt);min-height:100vh}

    /* ══ LOGIN OVERLAY ═══════════════════════════════════════════════ */
    #loginOverlay{
      position:fixed;inset:0;z-index:999;
      background:rgba(5,8,15,.97);backdrop-filter:blur(12px);
      display:flex;align-items:center;justify-content:center;
    }
    .login-box{
      background:var(--card);border:1px solid var(--border);border-radius:20px;
      padding:2.5rem 2rem;width:min(400px,90vw);text-align:center;
      box-shadow:0 24px 80px rgba(0,0,0,.5);
    }
    .login-box .ico{font-size:2.8rem;margin-bottom:.8rem}
    .login-box h2{font-size:1.4rem;font-weight:800;margin-bottom:.3rem}
    .login-box p{font-size:.82rem;color:var(--sub);margin-bottom:1.8rem}
    .login-field{
      width:100%;background:var(--card2);border:1px solid var(--border);
      border-radius:10px;padding:.75rem 1rem;color:var(--txt);
      font-family:var(--fa);font-size:.95rem;margin-bottom:.9rem;
      transition:border-color .25s;outline:none;text-align:right;
    }
    .login-field:focus{border-color:var(--accent)}
    .login-btn{
      width:100%;background:linear-gradient(135deg,var(--accent),var(--accent2));
      border:none;border-radius:10px;padding:.8rem;color:#000;
      font-family:var(--fa);font-size:1rem;font-weight:800;cursor:pointer;
      transition:opacity .2s;
    }
    .login-btn:hover{opacity:.88}
    .login-err{color:var(--red);font-size:.82rem;margin-top:.6rem;min-height:1.2em}

    /* ══ HEADER ══════════════════════════════════════════════════════ */
    header{
      background:rgba(5,8,15,.95);backdrop-filter:blur(20px);
      border-bottom:1px solid var(--border);padding:0 clamp(1rem,3vw,2.5rem);
      position:sticky;top:0;z-index:100;
    }
    .hdr{max-width:1400px;margin:auto;display:flex;align-items:center;justify-content:space-between;height:62px;gap:1rem}
    .logo{display:flex;align-items:center;gap:.6rem}
    .logo-ico{width:36px;height:36px;border-radius:9px;background:linear-gradient(135deg,var(--purple),#6b3fff);
      display:grid;place-items:center;font-size:1.1rem;box-shadow:0 0 14px #9c6bff55}
    .logo-txt{font-weight:900;font-size:1.1rem;background:linear-gradient(90deg,var(--purple),#c8a0ff);
      -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
    .logo-tag{font-size:.65rem;background:rgba(156,107,255,.15);border:1px solid rgba(156,107,255,.3);
      color:var(--purple);border-radius:20px;padding:.15rem .5rem;font-weight:700;letter-spacing:.5px}
    .hdr-r{display:flex;align-items:center;gap:.75rem}
    .hdr-btn{
      background:var(--card);border:1px solid var(--border);border-radius:8px;
      padding:.38rem .85rem;color:var(--sub);font-family:var(--fa);font-size:.78rem;
      cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:.35rem;
    }
    .hdr-btn:hover{border-color:var(--accent);color:var(--accent)}
    .hdr-btn.danger:hover{border-color:var(--red);color:var(--red)}

    /* ══ LAYOUT ══════════════════════════════════════════════════════ */
    .wrap{max-width:1400px;margin:auto;padding:1.8rem clamp(1rem,3vw,2.5rem) 4rem;display:grid;grid-template-columns:1fr 360px;gap:1.5rem}
    @media(max-width:900px){.wrap{grid-template-columns:1fr}}

    /* ══ SECTION TITLES ══════════════════════════════════════════════ */
    .sec-title{
      font-size:.7rem;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;
      color:var(--sub);margin-bottom:1rem;display:flex;align-items:center;gap:.5rem;
    }
    .sec-title::before{content:'';flex:1;height:1px;background:var(--border)}
    .sec-title::after{content:'';flex:1;height:1px;background:var(--border)}

    /* ══ STATS ROW ═══════════════════════════════════════════════════ */
    .stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:.8rem;margin-bottom:1.6rem}
    @media(max-width:600px){.stats-row{grid-template-columns:repeat(2,1fr)}}
    .stat-card{
      background:var(--card);border:1px solid var(--border);border-radius:12px;
      padding:.9rem 1rem;display:flex;flex-direction:column;gap:.25rem;
    }
    .stat-card .lbl{font-size:.72rem;color:var(--sub)}
    .stat-card .num{font-family:var(--fe);font-size:1.8rem;font-weight:700;line-height:1}
    .stat-card.red .num{color:var(--red)}
    .stat-card.green .num{color:var(--green)}
    .stat-card.blue .num{color:var(--accent)}
    .stat-card.orange .num{color:var(--orange)}

    /* ══ TABLE ═══════════════════════════════════════════════════════ */
    .table-wrap{background:var(--card);border:1px solid var(--border);border-radius:16px;overflow:hidden}
    .table-toolbar{
      display:flex;align-items:center;justify-content:space-between;gap:1rem;
      padding:.8rem 1rem;border-bottom:1px solid var(--border);flex-wrap:wrap;
    }
    .search-box{
      display:flex;align-items:center;gap:.5rem;background:var(--card2);
      border:1px solid var(--border);border-radius:8px;padding:.35rem .75rem;
      flex:1;min-width:180px;max-width:280px;
    }
    .search-box input{
      background:transparent;border:none;outline:none;color:var(--txt);
      font-family:var(--fa);font-size:.83rem;width:100%;
    }
    .search-box input::placeholder{color:var(--sub)}
    .toolbar-actions{display:flex;gap:.5rem}
    .tbtn{
      border-radius:8px;border:1px solid var(--border);background:transparent;
      padding:.35rem .75rem;font-family:var(--fa);font-size:.78rem;cursor:pointer;
      transition:all .2s;color:var(--sub);display:flex;align-items:center;gap:.3rem;white-space:nowrap;
    }
    .tbtn:hover{border-color:var(--accent);color:var(--accent)}
    .tbtn.primary{background:rgba(0,212,255,.1);border-color:var(--accent);color:var(--accent);font-weight:700}
    .tbtn.primary:hover{background:rgba(0,212,255,.2)}
    .tbtn.del{border-color:transparent}
    .tbtn.del:hover{border-color:var(--red);color:var(--red)}

    table{width:100%;border-collapse:collapse}
    thead tr{border-bottom:1px solid var(--border)}
    thead th{
      padding:.65rem 1rem;text-align:right;font-size:.72rem;font-weight:700;
      color:var(--sub);letter-spacing:.5px;white-space:nowrap;
    }
    tbody tr{border-bottom:1px solid rgba(30,40,60,.5);transition:background .15s}
    tbody tr:last-child{border-bottom:none}
    tbody tr:hover{background:rgba(255,255,255,.02)}
    tbody td{padding:.65rem 1rem;font-size:.83rem;vertical-align:middle}
    .td-teams{display:flex;flex-direction:column;gap:.15rem}
    .td-score{font-family:var(--fe);font-size:1rem;font-weight:700;white-space:nowrap}
    .td-status{
      display:inline-flex;align-items:center;gap:.3rem;
      font-size:.7rem;font-weight:700;padding:.18rem .55rem;border-radius:20px;white-space:nowrap;
    }
    .td-status.live{background:rgba(255,59,59,.14);color:var(--red);border:1px solid var(--red)44}
    .td-status.ended{background:rgba(90,106,128,.11);color:var(--gray);border:1px solid rgba(90,106,128,.28)}
    .td-min{font-family:var(--fe);font-size:.82rem;color:var(--sub);white-space:nowrap}
    .action-btns{display:flex;gap:.35rem}
    .act{
      width:28px;height:28px;border-radius:6px;border:1px solid var(--border);
      background:transparent;display:grid;place-items:center;cursor:pointer;
      font-size:.8rem;color:var(--sub);transition:all .18s;
    }
    .act:hover.edit{border-color:var(--accent);color:var(--accent);background:rgba(0,212,255,.08)}
    .act:hover.del{border-color:var(--red);color:var(--red);background:rgba(255,59,59,.08)}
    .act:hover.tog{border-color:var(--green);color:var(--green);background:rgba(0,230,118,.08)}
    .empty-row td{text-align:center;padding:3rem;color:var(--sub);font-size:.85rem}

    /* ══ SIDE PANEL ══════════════════════════════════════════════════ */
    .side{display:flex;flex-direction:column;gap:1.2rem}

    /* ADD / EDIT FORM */
    .form-card{
      background:var(--card);border:1px solid var(--border);border-radius:16px;
      overflow:hidden;
    }
    .form-head{
      padding:.85rem 1.1rem;border-bottom:1px solid var(--border);
      display:flex;align-items:center;justify-content:space-between;
    }
    .form-head h3{font-size:.9rem;font-weight:700}
    .form-head .mode-tag{
      font-size:.65rem;font-weight:700;padding:.15rem .5rem;border-radius:20px;letter-spacing:.5px;
    }
    .mode-tag.add{background:rgba(0,230,118,.12);color:var(--green);border:1px solid rgba(0,230,118,.3)}
    .mode-tag.edit{background:rgba(255,152,0,.12);color:var(--orange);border:1px solid rgba(255,152,0,.3)}
    .form-body{padding:1rem 1.1rem 1.2rem;display:flex;flex-direction:column;gap:.7rem}

    .field-group{display:grid;grid-template-columns:1fr 1fr;gap:.6rem}
    .field{display:flex;flex-direction:column;gap:.3rem}
    .field label{font-size:.72rem;color:var(--sub);font-weight:600}
    .field input,.field select{
      background:var(--card2);border:1px solid var(--border);border-radius:8px;
      padding:.55rem .75rem;color:var(--txt);font-family:var(--fa);font-size:.85rem;
      outline:none;transition:border-color .22s;
    }
    .field input:focus,.field select:focus{border-color:var(--accent)}
    .field select option{background:var(--card2)}
    .field.full{grid-column:1/-1}

    .score-row{display:grid;grid-template-columns:1fr auto 1fr;align-items:end;gap:.5rem}
    .score-sep{text-align:center;font-family:var(--fe);font-size:1.4rem;color:var(--sub);padding-bottom:.45rem}

    .form-actions{display:flex;gap:.6rem;margin-top:.3rem}
    .fbtn{
      flex:1;padding:.65rem;border-radius:9px;border:none;
      font-family:var(--fa);font-size:.88rem;font-weight:700;cursor:pointer;transition:opacity .2s;
    }
    .fbtn.save{background:linear-gradient(135deg,var(--accent),var(--accent2));color:#000}
    .fbtn.save:hover{opacity:.88}
    .fbtn.cancel{background:var(--card2);border:1px solid var(--border);color:var(--sub)}
    .fbtn.cancel:hover{border-color:var(--red);color:var(--red)}

    /* QUICK ACTIONS */
    .quick-card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:1.1rem}
    .quick-card h3{font-size:.85rem;font-weight:700;margin-bottom:.85rem;display:flex;align-items:center;gap:.4rem}
    .quick-grid{display:grid;grid-template-columns:1fr 1fr;gap:.6rem}
    .qbtn{
      padding:.6rem .5rem;border-radius:9px;border:1px solid var(--border);background:var(--card2);
      color:var(--sub);font-family:var(--fa);font-size:.78rem;cursor:pointer;transition:all .2s;
      display:flex;flex-direction:column;align-items:center;gap:.25rem;text-align:center;
    }
    .qbtn .qi{font-size:1.2rem}
    .qbtn:hover.ql{border-color:var(--red);color:var(--red);background:rgba(255,59,59,.07)}
    .qbtn:hover.qe{border-color:var(--gray);color:var(--gray);background:rgba(90,106,128,.07)}
    .qbtn:hover.qc{border-color:var(--orange);color:var(--orange);background:rgba(255,152,0,.07)}
    .qbtn:hover.qd{border-color:var(--purple);color:var(--purple);background:rgba(156,107,255,.07)}

    /* TOAST */
    #toast{
      position:fixed;bottom:1.5rem;left:50%;transform:translateX(-50%) translateY(80px);
      background:var(--card2);border:1px solid var(--border);border-radius:30px;
      padding:.55rem 1.3rem;font-size:.8rem;display:flex;align-items:center;gap:.45rem;
      transition:transform .3s ease;z-index:999;white-space:nowrap;pointer-events:none;
    }
    #toast.show{transform:translateX(-50%) translateY(0)}
    #toast.ok{color:var(--green);border-color:rgba(0,230,118,.3)}
    #toast.err{color:var(--red);border-color:rgba(255,59,59,.3)}
    #toast.info{color:var(--accent);border-color:rgba(0,212,255,.3)}

    /* CONFIRM MODAL */
    #confirmModal{
      position:fixed;inset:0;z-index:998;background:rgba(5,8,15,.85);backdrop-filter:blur(8px);
      display:none;align-items:center;justify-content:center;
    }
    #confirmModal.open{display:flex}
    .confirm-box{
      background:var(--card);border:1px solid var(--border);border-radius:16px;
      padding:2rem;width:min(360px,90vw);text-align:center;
    }
    .confirm-box .ico{font-size:2.2rem;margin-bottom:.6rem}
    .confirm-box h3{font-size:1rem;font-weight:700;margin-bottom:.4rem}
    .confirm-box p{font-size:.82rem;color:var(--sub);margin-bottom:1.4rem}
    .confirm-btns{display:flex;gap:.7rem}
    .cbtn{flex:1;padding:.62rem;border-radius:9px;border:none;font-family:var(--fa);font-size:.88rem;font-weight:700;cursor:pointer}
    .cbtn.yes{background:var(--red);color:#fff}
    .cbtn.no{background:var(--card2);border:1px solid var(--border);color:var(--sub)}

    ::-webkit-scrollbar{width:5px}
    ::-webkit-scrollbar-track{background:var(--bg)}
    ::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}

    @media(max-width:700px){
      thead .hide-m{display:none}
      tbody .hide-m{display:none}
      .field-group{grid-template-columns:1fr}
    }
  </style>
</head>
<body>

<!-- ══ LOGIN ════════════════════════════════════════════════════════ -->
<div id="loginOverlay">
  <div class="login-box">
    <div class="ico">🔐</div>
    <h2>لوحة تحكم الأدمن</h2>
    <p>أدخل كلمة المرور للمتابعة</p>
    <input class="login-field" type="password" id="pwInput" placeholder="كلمة المرور" autocomplete="current-password"/>
    <button class="login-btn" onclick="doLogin()">دخول</button>
    <div class="login-err" id="loginErr"></div>
  </div>
</div>

<!-- ══ CONFIRM MODAL ════════════════════════════════════════════════ -->
<div id="confirmModal">
  <div class="confirm-box">
    <div class="ico">⚠️</div>
    <h3>تأكيد الحذف</h3>
    <p id="confirmMsg">هل أنت متأكد من حذف هذه المباراة؟</p>
    <div class="confirm-btns">
      <button class="cbtn yes" id="confirmYes">حذف</button>
      <button class="cbtn no" onclick="closeConfirm()">إلغاء</button>
    </div>
  </div>
</div>

<!-- ══ TOAST ═════════════════════════════════════════════════════════ -->
<div id="toast"></div>

<!-- ══ HEADER ════════════════════════════════════════════════════════ -->
<header>
  <div class="hdr">
    <div class="logo">
      <div class="logo-ico">⚙️</div>
      <span class="logo-txt">LiveScores Admin</span>
      <span class="logo-tag">ADMIN</span>
    </div>
    <div class="hdr-r">
      <button class="hdr-btn" onclick="fetchData()">🔄 تحديث</button>
      <button class="hdr-btn" onclick="window.open('index.html','_blank')">👁 عرض المشاهد</button>
      <button class="hdr-btn danger" onclick="logout()">🚪 خروج</button>
    </div>
  </div>
</header>

<!-- ══ MAIN ══════════════════════════════════════════════════════════ -->
<div class="wrap">

  <!-- LEFT: stats + table -->
  <div>
    <!-- stats -->
    <div class="stats-row">
      <div class="stat-card blue"><span class="lbl">إجمالي المباريات</span><span class="num" id="sAll">—</span></div>
      <div class="stat-card red"><span class="lbl">🔴 مباشر</span><span class="num" id="sLive">—</span></div>
      <div class="stat-card green"><span class="lbl">✅ انتهت</span><span class="num" id="sEnd">—</span></div>
      <div class="stat-card orange"><span class="lbl">🏆 البطولات</span><span class="num" id="sLeague">—</span></div>
    </div>

    <!-- table -->
    <div class="table-wrap">
      <div class="table-toolbar">
        <div class="search-box">
          🔍 <input type="text" id="searchInp" placeholder="بحث عن فريق أو بطولة…" oninput="filterTable()"/>
        </div>
        <div class="toolbar-actions">
          <button class="tbtn" onclick="endAllLive()" title="إنهاء جميع المباشر">⏹ إنهاء الكل</button>
          <button class="tbtn del" onclick="confirmDeleteAll()" title="حذف جميع المباريات">🗑 حذف الكل</button>
        </div>
      </div>
      <div style="overflow-x:auto">
        <table>
          <thead>
            <tr>
              <th>المباراة</th>
              <th>النتيجة</th>
              <th>الحالة</th>
              <th class="hide-m">الدقيقة</th>
              <th class="hide-m">البطولة</th>
              <th class="hide-m">التاريخ</th>
              <th></th>
            </tr>
          </thead>
          <tbody id="tbody"></tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- RIGHT: form + quick actions -->
  <div class="side">

    <!-- Add/Edit form -->
    <div class="form-card">
      <div class="form-head">
        <h3 id="formTitle">➕ إضافة مباراة جديدة</h3>
        <span class="mode-tag add" id="modeTag">جديد</span>
      </div>
      <div class="form-body">
        <input type="hidden" id="editId"/>

        <div class="field-group">
          <div class="field full">
            <label>الفريق الأول (الضيف)</label>
            <input type="text" id="fHome" placeholder="مثال: ريال مدريد"/>
          </div>
          <div class="field full">
            <label>الفريق الثاني (المضيف)</label>
            <input type="text" id="fAway" placeholder="مثال: برشلونة"/>
          </div>
        </div>

        <div>
          <label style="font-size:.72rem;color:var(--sub);font-weight:600;display:block;margin-bottom:.4rem">النتيجة</label>
          <div class="score-row">
            <div class="field"><input type="number" id="fS1" placeholder="0" min="0" style="text-align:center;font-family:var(--fe);font-size:1.3rem;font-weight:700"/></div>
            <div class="score-sep">–</div>
            <div class="field"><input type="number" id="fS2" placeholder="0" min="0" style="text-align:center;font-family:var(--fe);font-size:1.3rem;font-weight:700"/></div>
          </div>
        </div>

        <div class="field-group">
          <div class="field">
            <label>الحالة</label>
            <select id="fStatus">
              <option value="مباشر">🔴 مباشر</option>
              <option value="انتهت">✅ انتهت</option>
              <option value="لم تبدأ">⏳ لم تبدأ</option>
              <option value="موقوفة">⏸ موقوفة</option>
            </select>
          </div>
          <div class="field">
            <label>الدقيقة</label>
            <input type="number" id="fMin" placeholder="مثال: 67" min="0" max="120"/>
          </div>
        </div>

        <div class="field">
          <label>البطولة / الدوري</label>
          <input type="text" id="fLeague" placeholder="مثال: الدوري الإسباني"/>
        </div>

        <div class="field">
          <label>التاريخ والوقت</label>
          <input type="text" id="fDate" placeholder="مثال: 13/04/2026 - 21:00"/>
        </div>

        <div class="form-actions">
          <button class="fbtn save" onclick="submitForm()">💾 حفظ</button>
          <button class="fbtn cancel" id="cancelBtn" onclick="resetForm()" style="display:none">✕ إلغاء</button>
        </div>
      </div>
    </div>

    <!-- Quick actions -->
    <div class="quick-card">
      <h3>⚡ إجراءات سريعة</h3>
      <div class="quick-grid">
        <button class="qbtn ql" onclick="setAllStatus('مباشر')"><span class="qi">🔴</span>تشغيل الكل مباشر</button>
        <button class="qbtn qe" onclick="setAllStatus('انتهت')"><span class="qi">✅</span>إنهاء جميع المباريات</button>
        <button class="qbtn qc" onclick="clearAllScores()"><span class="qi">🔄</span>تصفير النتائج</button>
        <button class="qbtn qd" onclick="fetchData()"><span class="qi">📡</span>تحديث البيانات</button>
      </div>
    </div>

    <!-- API info -->
    <div style="background:var(--card);border:1px solid var(--border);border-radius:12px;padding:.9rem 1rem;font-size:.75rem;color:var(--sub)">
      <div style="display:flex;align-items:center;gap:.4rem;margin-bottom:.4rem;font-weight:700;color:var(--txt)">
        📡 معلومات الـ API
      </div>
      <div style="display:flex;flex-direction:column;gap:.25rem">
        <span>الرابط: <span style="color:var(--accent);font-family:monospace;font-size:.7rem">sheetdb.io/api/v1/uyktjb2tkvipj</span></span>
        <span id="apiStatus">الحالة: جارٍ الاتصال…</span>
        <span id="lastSync">آخر مزامنة: —</span>
      </div>
    </div>

  </div>
</div>

<script>
/* ═══════════════════════════════════════════════════════
   AUTH
═══════════════════════════════════════════════════════ */
const PASS = 'admin123'; // ← غيّر كلمة المرور هنا

function doLogin(){
  const v=document.getElementById('pwInput').value;
  if(v===PASS){
    document.getElementById('loginOverlay').style.display='none';
    sessionStorage.setItem('adm','1');
    fetchData();
    setInterval(fetchData,5000);
  } else {
    document.getElementById('loginErr').textContent='❌ كلمة المرور خاطئة';
    document.getElementById('pwInput').value='';
  }
}
document.getElementById('pwInput').addEventListener('keydown',e=>{if(e.key==='Enter')doLogin()});

function logout(){
  sessionStorage.removeItem('adm');
  location.reload();
}

// keep session
if(sessionStorage.getItem('adm')==='1'){
  document.getElementById('loginOverlay').style.display='none';
  fetchData();
  setInterval(fetchData,5000);
}

/* ═══════════════════════════════════════════════════════
   API
═══════════════════════════════════════════════════════ */
const API='https://sheetdb.io/api/v1/uyktjb2tkvipj';
let allData=[];
let searchTerm='';

function ex(m){return{
  home:m.home_team||m.الفريق_الاول||m.team1||'الفريق الأول',
  away:m.away_team||m.الفريق_الثاني||m.team2||'الفريق الثاني',
  score:m.score||m.النتيجة||'0 - 0',
  status:(m.status||m.الحالة||'انتهت').trim(),
  dt:m.datetime||m.التاريخ||m.date||'',
  league:m.league||m.الدوري||m.competition||'',
  minute:m.minute||m.الدقيقة||'',
}}
function rowId(m,i){return String(m.id||m.rowid||m.row_id||i)}

async function api(method,path,body){
  const r=await fetch(API+path,{
    method,mode:'cors',
    headers:{'Content-Type':'application/json','Accept':'application/json'},
    body:body?JSON.stringify(body):undefined
  });
  if(!r.ok)throw new Error(`HTTP ${r.status}`);
  return r.json();
}

/* ═══════════════════════════════════════════════════════
   FETCH & RENDER TABLE
═══════════════════════════════════════════════════════ */
async function fetchData(){
  try{
    const d=await api('GET','');
    allData=Array.isArray(d)?d:(d.data||[]);
    renderTable();
    updateStats();
    document.getElementById('apiStatus').textContent='الحالة: ✅ متصل';
    document.getElementById('lastSync').textContent='آخر مزامنة: '+new Date().toLocaleTimeString('ar-DZ',{hour:'2-digit',minute:'2-digit',second:'2-digit'});
  }catch(e){
    console.warn(e);
    document.getElementById('apiStatus').textContent='الحالة: ❌ خطأ في الاتصال';
    toast('فشل تحميل البيانات','err');
  }
}

function updateStats(){
  const lc=allData.filter(m=>ex(m).status==='مباشر').length;
  const leagues=new Set(allData.map(m=>ex(m).league).filter(Boolean)).size;
  document.getElementById('sAll').textContent=allData.length;
  document.getElementById('sLive').textContent=lc;
  document.getElementById('sEnd').textContent=allData.length-lc;
  document.getElementById('sLeague').textContent=leagues;
}

function filterTable(){
  searchTerm=document.getElementById('searchInp').value.trim().toLowerCase();
  renderTable();
}

function renderTable(){
  const tbody=document.getElementById('tbody');
  let rows=allData;
  if(searchTerm) rows=rows.filter(m=>{
    const{home,away,league}=ex(m);
    return (home+away+league).toLowerCase().includes(searchTerm);
  });

  if(!rows.length){
    tbody.innerHTML=`<tr class="empty-row"><td colspan="7">لا توجد نتائج</td></tr>`;return;
  }

  tbody.innerHTML=rows.map((m,i)=>{
    const{home,away,score,status,dt,league,minute}=ex(m);
    const rid=rowId(m,i);
    const isLive=status==='مباشر';
    const p=score.replace(/\s/g,'').split('-');
    return `<tr>
      <td><div class="td-teams"><span style="font-weight:700">${home}</span><span style="color:var(--sub);font-size:.75rem">vs ${away}</span></div></td>
      <td><span class="td-score">${p[0]||0} : ${p[1]||0}</span></td>
      <td><span class="td-status ${isLive?'live':'ended'}">${isLive?'🔴':'✅'} ${status}</span></td>
      <td class="hide-m"><span class="td-min">${minute?minute+"'":'—'}</span></td>
      <td class="hide-m" style="color:var(--sub);font-size:.78rem">${league||'—'}</td>
      <td class="hide-m" style="color:var(--sub);font-size:.78rem">${dt||'—'}</td>
      <td>
        <div class="action-btns">
          <button class="act edit" onclick="editRow('${rid}')" title="تعديل">✏️</button>
          <button class="act tog" onclick="toggleStatus('${rid}')" title="${isLive?'إنهاء':'تشغيل مباشر'}">${isLive?'⏹':'▶'}</button>
          <button class="act del" onclick="confirmDelete('${rid}')" title="حذف">🗑</button>
        </div>
      </td>
    </tr>`;
  }).join('');
}

/* ═══════════════════════════════════════════════════════
   ADD / EDIT FORM
═══════════════════════════════════════════════════════ */
function resetForm(){
  document.getElementById('editId').value='';
  document.getElementById('fHome').value='';
  document.getElementById('fAway').value='';
  document.getElementById('fS1').value='';
  document.getElementById('fS2').value='';
  document.getElementById('fStatus').value='مباشر';
  document.getElementById('fMin').value='';
  document.getElementById('fLeague').value='';
  document.getElementById('fDate').value='';
  document.getElementById('formTitle').textContent='➕ إضافة مباراة جديدة';
  document.getElementById('modeTag').textContent='جديد';
  document.getElementById('modeTag').className='mode-tag add';
  document.getElementById('cancelBtn').style.display='none';
}

function editRow(rid){
  const m=allData.find((m,i)=>rowId(m,i)===rid);
  if(!m)return;
  const{home,away,score,status,dt,league,minute}=ex(m);
  const p=score.replace(/\s/g,'').split('-');
  document.getElementById('editId').value=rid;
  document.getElementById('fHome').value=home;
  document.getElementById('fAway').value=away;
  document.getElementById('fS1').value=p[0]?.trim()||'0';
  document.getElementById('fS2').value=p[1]?.trim()||'0';
  document.getElementById('fStatus').value=status;
  document.getElementById('fMin').value=minute||'';
  document.getElementById('fLeague').value=league||'';
  document.getElementById('fDate').value=dt||'';
  document.getElementById('formTitle').textContent='✏️ تعديل المباراة';
  document.getElementById('modeTag').textContent='تعديل';
  document.getElementById('modeTag').className='mode-tag edit';
  document.getElementById('cancelBtn').style.display='block';
  // scroll to form
  document.querySelector('.form-card').scrollIntoView({behavior:'smooth',block:'start'});
}

async function submitForm(){
  const home=document.getElementById('fHome').value.trim();
  const away=document.getElementById('fAway').value.trim();
  const s1=document.getElementById('fS1').value||'0';
  const s2=document.getElementById('fS2').value||'0';
  const status=document.getElementById('fStatus').value;
  const minute=document.getElementById('fMin').value.trim();
  const league=document.getElementById('fLeague').value.trim();
  const dt=document.getElementById('fDate').value.trim();
  const editId=document.getElementById('editId').value;

  if(!home||!away){toast('يرجى إدخال اسمي الفريقين','err');return}

  const row={
    home_team:home, away_team:away,
    score:`${s1} - ${s2}`,
    status, minute, league, datetime:dt
  };

  try{
    if(editId){
      await api('PATCH',`/id/${editId}`,{data:row});
      toast('✅ تم تحديث المباراة','ok');
    } else {
      await api('POST','',{data:row});
      toast('✅ تمت إضافة المباراة','ok');
    }
    resetForm();
    await fetchData();
  }catch(e){
    console.error(e);
    toast('❌ فشلت العملية: '+e.message,'err');
  }
}

/* ═══════════════════════════════════════════════════════
   TOGGLE STATUS
═══════════════════════════════════════════════════════ */
async function toggleStatus(rid){
  const m=allData.find((m,i)=>rowId(m,i)===rid);
  if(!m)return;
  const cur=ex(m).status;
  const next=cur==='مباشر'?'انتهت':'مباشر';
  try{
    await api('PATCH',`/id/${rid}`,{data:{status:next}});
    toast(`تم تغيير الحالة إلى "${next}"`, 'info');
    await fetchData();
  }catch(e){toast('❌ فشل تغيير الحالة','err')}
}

/* ═══════════════════════════════════════════════════════
   DELETE
═══════════════════════════════════════════════════════ */
let pendingDeleteId=null;
function confirmDelete(rid){
  pendingDeleteId=rid;
  document.getElementById('confirmMsg').textContent='هل أنت متأكد من حذف هذه المباراة؟ لا يمكن التراجع.';
  document.getElementById('confirmYes').onclick=()=>doDelete(rid);
  document.getElementById('confirmModal').classList.add('open');
}
function confirmDeleteAll(){
  document.getElementById('confirmMsg').textContent='هل أنت متأكد من حذف جميع المباريات؟ ⚠️ لا يمكن التراجع!';
  document.getElementById('confirmYes').onclick=doDeleteAll;
  document.getElementById('confirmModal').classList.add('open');
}
function closeConfirm(){document.getElementById('confirmModal').classList.remove('open')}

async function doDelete(rid){
  closeConfirm();
  try{
    await api('DELETE',`/id/${rid}`);
    toast('🗑 تم حذف المباراة','ok');
    await fetchData();
  }catch(e){toast('❌ فشل الحذف','err')}
}

async function doDeleteAll(){
  closeConfirm();
  try{
    // delete one by one (SheetDB doesn't have bulk delete)
    for(let i=0;i<allData.length;i++){
      const rid=rowId(allData[i],i);
      await api('DELETE',`/id/${rid}`);
    }
    toast('🗑 تم حذف جميع المباريات','ok');
    await fetchData();
  }catch(e){toast('❌ فشل حذف الكل: '+e.message,'err')}
}

/* ═══════════════════════════════════════════════════════
   QUICK ACTIONS
═══════════════════════════════════════════════════════ */
async function setAllStatus(s){
  try{
    for(let i=0;i<allData.length;i++){
      const rid=rowId(allData[i],i);
      await api('PATCH',`/id/${rid}`,{data:{status:s}});
    }
    toast(`✅ تم تحديث حالة جميع المباريات إلى "${s}"`, 'ok');
    await fetchData();
  }catch(e){toast('❌ فشلت العملية','err')}
}

function endAllLive(){ setAllStatus('انتهت') }

async function clearAllScores(){
  try{
    for(let i=0;i<allData.length;i++){
      const rid=rowId(allData[i],i);
      await api('PATCH',`/id/${rid}`,{data:{score:'0 - 0', minute:''}});
    }
    toast('🔄 تم تصفير جميع النتائج','ok');
    await fetchData();
  }catch(e){toast('❌ فشلت العملية','err')}
}

/* ═══════════════════════════════════════════════════════
   TOAST
═══════════════════════════════════════════════════════ */
let toastTimer;
function toast(msg,type='info'){
  const t=document.getElementById('toast');
  t.textContent=msg;
  t.className='show '+type;
  clearTimeout(toastTimer);
  toastTimer=setTimeout(()=>{t.className=''},2200);
}
</script>
</body>
</html>
